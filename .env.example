# Copy this file to .env before running docker compose

# --- Postgres ---
POSTGRES_USER=studymate
POSTGRES_PASSWORD=studymate
POSTGRES_DB=studymate

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI (all local/free for MVP) ---
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# These get overridden inside docker-compose.yml for the backend container
# (kept here so you can also run the backend outside Docker if you want)
DATABASE_URL=postgresql+psycopg://studymate:studymate@localhost:5432/studymate
CHROMA_HOST=localhost
CHROMA_PORT=8001
OLLAMA_BASE_URL=http://localhost:11434
